{
  "name": "vulnsig-digest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "email dev -d preview -p 3000",
    "bundle": "esbuild src/handler.ts --bundle --platform=node --target=node22 --format=cjs --jsx=automatic --external:@aws-sdk/client-s3 --outfile=dist/handler.js",
    "curate": "tsx src/curate-debug.ts",
    "send": "tsx src/send-test.ts",
    "test": "vitest run",
    "lint": "eslint . && tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@aws-sdk/client-s3": "^3.1015.0",
    "@react-email/components": "^1.0.9",
    "@react-email/render": "^2.0.4",
    "postmark": "^4.0.7",
    "vulnsig": "^1.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^20.17.0",
    "@types/react": "^19.0.0",
    "dotenv": "^16.4.0",
    "eslint": "^9.0.0",
    "prettier": "^3.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.2.4",
    "react-email": "^3.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "undici": "^7.24.0",
    "vitest": "^3.0.0"
  }
