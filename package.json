{
  "name": "vulnsig-digest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "email dev -d preview -p 3000",
    "build": "tsup src/handler.ts --format esm --target node20 --out-dir dist --clean",
    "package": "npm run build && cd dist && zip -r ../vulnsig-digest.zip .",
    "send-test": "tsx src/send-test.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@react-email/components": "^0.0.31",
    "@react-email/render": "^1.0.3",
    "@react-email/tailwind": "^2.0.5",
    "postmark": "^4.0.5",
    "vulnsig": "^1.3.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^20.17.0",
    "@types/react": "^19.0.0",
    "dotenv": "^16.4.0",
    "prettier": "^3.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.2.4",
    "react-email": "^3.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
